[
  {
    "clean": ["~"]
  },
  { 
    "link": {
      "~/.gitconfig": "home/gitconfig",
      "~/.zshrc": "home/zshrc",
      "~/.Xresources": "home/Xresources",
      "~/.xinitrc": "home/xinitrc",
      "~/.config/i3/config": {
        "path": "config/i3",
        "create": "true"
      },
      "~/.config/nvim/init.vim": {
        "path": "config/neo.vim",
        "create": "true"
      }
    }
  }
]
