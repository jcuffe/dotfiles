;; Get packages from Melpa
(require 'package)
(add-to-list 'package-archives '("melpa" . "https://melpa.org/packages/"))
(package-initialize)

(setq version-control t       ;; Responsible backup settings
      kept-new-versions 10    ;; It's affordable
      kept-old-versions 0     ;; No thanks
      delete-old-versions t   ;; Delete without asking
      backup-by-copying t     ;; Don't clobber symlinks
      vc-make-backup-files t  ;; For between commits 
      vc-follow-symlinks t   ;; Auto-follow symlinks to git-controlled files
      backup-directory-alist
      `((".*" . ,temporary-file-directory))
      auto-save-file-name-transforms
      `((".*" ,temporary-file-directory t)))


(menu-bar-mode 0)
(show-paren-mode t)
;(global-hl-line-mode 1)

;; My keybinds
(global-set-key (kbd "C-x g") 'magit-status)                    ;; Git
(global-set-key (kbd "C-x M-g") 'magit-dispatch-popup)          ;; Git extras


(custom-set-variables
 ;; custom-set-variables was added by Custom.
 ;; If you edit it by hand, you could mess it up, so be careful.
 ;; Your init file should contain only one such instance.
 ;; If there is more than one, they won't work right.
 '(package-selected-packages (quote (magit json-mode dash))))
(custom-set-faces
 ;; custom-set-faces was added by Custom.
 ;; If you edit it by hand, you could mess it up, so be careful.
 ;; Your init file should contain only one such instance.
 ;; If there is more than one, they won't work right.
 '(font-lock-comment-face ((t (:foreground "brightgreen"))))
 '(font-lock-string-face ((t (:foreground "magenta")))))
