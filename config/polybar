[colors]
background = ${xrdb:background}
foreground = ${xrdb:foreground}

black = ${xrdb:color0}
bblack = ${xrdb:color8}
red = ${xrdb:color1}
bred = ${xrdb:color9}
green = ${xrdb:color2}
bgreen = ${xrdb:color10}
yellow = ${xrdb:color3}
byellow = ${xrdb:color11}
blue = ${xrdb:color4}
bblue = ${xrdb:color12}
magenta = ${xrdb:color5}
bmagenta = ${xrdb:color13}
cyan = ${xrdb:color6}
bcyan = ${xrdb:color14}
white = ${xrdb:color7}
bwhite = ${xrdb:color15}

[bar/example]
width = 480
height = 25
offset-x = 720
offset-y = 10
fixed-center = true
override-redirect = true
wm-restack = i3

background = ${colors.bwhite}
foreground = ${colors.black}

line-size = 2

font-0 = Misc Tamsyn:size=15;2
font-1 = FontAwesome:size=12;3

modules-left = i3
modules-center = 
modules-right = date

[module/i3]
type = internal/i3
format = <label-state>
index-sort = true
wrapping-scroll = false
strip-wsnumbers = true

ws-icon-0 = 1;
ws-icon-1 = 2;
ws-icon-2 = 3;

label-focused-padding = 3
label-unfocused-padding = 3
label-visible-padding = 3
label-urgent-padding = 3

label-focused-foreground = ${colors.bwhite}
label-focused-background = ${colors.blue}

label-focused = %icon%
label-unfocused = %icon%
label-visible = %icon%
label-urgent = %icon%

[module/mpd]
type = internal/mpd
format-online = <label-song>  <icon-prev> <icon-stop> <toggle> <icon-next>

icon-prev = 
icon-stop = 
icon-play = 
icon-pause = 
icon-next = 

label-song-maxlen = 25
label-song-ellipsis = true

[module/cpu]
type = internal/cpu
interval = 1
label =   %percentage%%
label-padding = 3
label-background = ${colors.bblue}
label-foreground = ${colors.bwhite}

[module/memory]
type = internal/memory
interval = 1
label =   %percentage_used%%
label-padding = 3
label-background = ${colors.blue}
label-foreground = ${colors.bwhite}

[module/date]
type = internal/date
interval = 5
date = "%e %B - "
time = "%H:%M"
label-background = ${colors.magenta}
label-foreground = ${colors.bwhite}
label-padding = 3
label-font = 1
label = %date%%time%

[settings]
screenchange-reload = true
;compositing-background = xor
;compositing-background = screen
;compositing-foreground = source
;compositing-border = over

; vim:ft=dosini
