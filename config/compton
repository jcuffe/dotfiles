# Opacity
inactive-opacity = 0.6;
alpha-step = 0.07;

blur-kern = "3x3box";

fading = true;

# Shadow
shadow = true;
clear-shadow = true;
shadow-radius = 5;
shadow-offset-x = -5;
shadow-offset-y = -5;

focus-exclude = [
  "class_i = 'rofi'",
  "class_i = 'Firefox'"
];
shadow-exclude= [
  "class_i = 'tray'",
  "class_i = 'Conky'"
];